
# ══════════════════════════════════════════════════════════════
#  FINOVA — Environment Variables Template
#  Copy this file to .env and fill in your real values
#  DO NOT commit .env to git — only .env.example
# ══════════════════════════════════════════════════════════════


# 🗄️  DATABASE (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres.YOURPROJECT:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres?pgbouncer=true&connection_limit=1&pool_timeout=20&sslmode=require"
DIRECT_URL="postgresql://postgres.YOURPROJECT:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres"

# 🔐  SUPABASE
NEXT_PUBLIC_SUPABASE_URL=https://yourproject.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# 🌐  DOMAIN MAP
# Marketing website
NEXT_PUBLIC_BASE_URL=https://finovaos.app
# Main app / login / dashboard
NEXT_PUBLIC_APP_URL=https://usefinova.app
# Optional supporting subdomains
NEXT_PUBLIC_ADMIN_URL=https://admin.finovaos.app
NEXT_PUBLIC_API_URL=https://api.finovaos.app
NEXT_PUBLIC_AI_URL=https://ai.finovaos.app

# Local development override example:
# NEXT_PUBLIC_BASE_URL=http://localhost:3000
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# 🔑  SESSION SECRET (generate: openssl rand -base64 48)
SESSION_SECRET=your_strong_random_secret_min_32_chars
COMPANY_SECRET_MASTER_KEY=your_strong_random_secret_min_32_chars

# 📧  EMAIL — SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@finova.io
SMTP_PASS=your_email_app_password
SMTP_FROM="Finova <noreply@finova.io>"

# 📧  Email Addresses
EMAIL_SUPPORT=support@finova.io
EMAIL_BILLING=billing@finova.io
EMAIL_ADMIN=admin@finova.io
EMAIL_LEGAL=legal@finova.io
EMAIL_MARKETING=hello@finova.io
EMAIL_NOREPLY=noreply@finova.io

# 💳  STRIPE
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_publishable_key
NEXT_PUBLIC_PRICE_STARTER=price_your_starter_price_id
NEXT_PUBLIC_PRICE_STARTER_YEARLY=price_your_starter_yearly_price_id
NEXT_PUBLIC_PRICE_PRO=price_your_pro_price_id
NEXT_PUBLIC_PRICE_PRO_YEARLY=price_your_pro_yearly_price_id
NEXT_PUBLIC_PRICE_ENTERPRISE=price_your_enterprise_price_id
NEXT_PUBLIC_PRICE_ENTERPRISE_YEARLY=price_your_enterprise_yearly_price_id

# 🤖  AI
OPENAI_API_KEY=sk-proj-your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini
ANTHROPIC_API_KEY=your_anthropic_claude_api_key

# 💬  WHATSAPP (Meta Business API)
WHATSAPP_TOKEN=your_meta_whatsapp_access_token
WHATSAPP_PHONE_ID=your_whatsapp_phone_number_id

# 📱  SMS
SMS_API_URL=your_sms_provider_api_url
SMS_API_KEY=your_sms_api_key
SMS_FROM=Finova
SMS_API_AUTH_HEADER=Authorization
SMS_API_AUTH_SCHEME=Bearer

# 🔏  GOOGLE OAUTH
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# 🏦  PLAID (Bank Integration)
PLAID_ENV=sandbox
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret

# 🔒  ADMIN
ADMIN_SECRET=your_admin_secret_token

# 🔍  SEO
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_google_site_verification_code

# 🛠️  DEBUG
DEBUG_PRISMA=false
