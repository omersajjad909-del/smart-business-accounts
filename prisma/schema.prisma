generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  code          String
  name          String
  type          String
  parentId      String?
  partyType     String?
  inventoryTxns InventoryTxn[]

  city        String?
  phone       String?
  email       String?
  address     String?
  ntn         String?   // National Tax Number
  strn        String?   // Sales Tax Reg. No.
  bankIban    String?   // IBAN / Bank Account No.
  description String?   // Internal notes
  openDate    DateTime?
  openDebit   Float     @default(0)
  openCredit  Float     @default(0)
  creditDays  Int?
  creditLimit Float?

  voucherEntries VoucherEntry[]
  outwards       Outward[]

  salesInvoices    SalesInvoice[]    @relation("SalesCustomer")
  quotations       Quotation[]       @relation("QuotationCustomer")
  deliveryChallans DeliveryChallan[] @relation("ChallanCustomer")
  purchaseInvoices PurchaseInvoice[] @relation("PurchaseSupplier")
  purchaseOrders   PurchaseOrder[]   @relation("PurchaseSupplier")
  saleReturns      SaleReturn[]      @relation("SaleReturnCustomer")

  // Phase 1 Relations
  bankAccounts    BankAccount[]
  paymentReceipts PaymentReceipt[]
  expenseVouchers ExpenseVoucher[] @relation("ExpenseAccount")
  paymentVouchers ExpenseVoucher[] @relation("PaymentAccount")
  taxAccounts     TaxAccount[]
  advancePayments AdvancePayment[] @relation("SupplierAdvances")
  creditNotes     CreditNote[]     @relation("CreditNoteAccount")
  debitNotes      DebitNote[]      @relation("DebitNoteAccount")
  loans             Loan[]             @relation("LoanAccount")
  goodsReceiptNotes GoodsReceiptNote[] @relation("GRNSupplier")

  // Advanced Features
  budgets               Budget[]
  recurringTransactions RecurringTransaction[]

  // Financial Core
  ledgerEntries LedgerEntry[] @relation("AccountLedgerEntries")

  createdAt DateTime  @default(now())
  deletedAt DateTime?
  deletedBy String?
}

model ItemNew {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  code         String
  name         String
  category     String   @default("TRADING")  // TRADING | RAW_MATERIAL | FINISHED | SERVICE
  unit         String
  rate         Float    @default(0)           // Sale Rate
  purchaseRate Float    @default(0)           // Cost / Purchase Rate
  taxRate      Float    @default(0)           // GST / Sales Tax %
  minStock     Int      @default(0)
  barcode      String?  @unique
  description  String?
  createdAt    DateTime @default(now())

  stockRates   StockRate[]
  outwardItems OutwardItem[]

  quotationItems QuotationItem[]

  poItems           PurchaseOrderItem[]
  invoiceItems      PurchaseInvoiceItem[]
  inventoryTxns     InventoryTxn[]
  salesInvoiceItems SalesInvoiceItem[]
  SaleReturnItem    SaleReturnItem[]
  grnItems          GoodsReceiptNoteItem[]

  deletedAt            DateTime?
  deletedBy            String?
  deliveryChallanItems DeliveryChallanItem[]
}

model PurchaseOrder {
  id           String      @id @default(uuid())
  companyId    String?
  company      Company?    @relation(fields: [companyId], references: [id])
  branchId     String?
  branch       Branch?     @relation(fields: [branchId], references: [id])
  costCenterId String?
  costCenter   CostCenter? @relation(fields: [costCenterId], references: [id])

  poNo            String
  date            DateTime
  remarks         String
  status          String    @default("PENDING")
  approvalStatus  String    @default("DRAFT")
  approvedBy      String?
  approvedAt      DateTime?
  approvalRemarks String?

  supplierId String
  supplier   Account @relation("PurchaseSupplier", fields: [supplierId], references: [id])

  items             PurchaseOrderItem[]
  invoices          PurchaseInvoice[]
  goodsReceiptNotes GoodsReceiptNote[]

  createdAt DateTime @default(now())
}

model PurchaseOrderItem {
  id          String @id @default(uuid())
  poId        String
  itemId      String
  qty         Int
  rate        Float
  invoicedQty Int    @default(0)

  po   PurchaseOrder @relation(fields: [poId], references: [id])
  item ItemNew       @relation(fields: [itemId], references: [id])
}

model PurchaseInvoice {
  id           String      @id @default(uuid())
  companyId    String
  company      Company     @relation(fields: [companyId], references: [id])
  branchId     String?
  branch       Branch?     @relation(fields: [branchId], references: [id])
  costCenterId String?
  costCenter   CostCenter? @relation(fields: [costCenterId], references: [id])

  invoiceNo String
  date      DateTime

  poId String?
  po   PurchaseOrder? @relation(fields: [poId], references: [id])

  supplierId String
  supplier   Account @relation("PurchaseSupplier", fields: [supplierId], references: [id])

  total Float

  taxConfigId String?
  taxConfig   TaxConfiguration? @relation("PurchaseTax", fields: [taxConfigId], references: [id])

  items PurchaseInvoiceItem[]

  approvalStatus  String    @default("DRAFT") // DRAFT | PENDING | APPROVED | REJECTED
  approvedBy      String?
  approvedAt      DateTime?
  approvalRemarks String?

  createdAt DateTime  @default(now())
  deletedAt DateTime?
  deletedBy String?
}

model PurchaseInvoiceItem {
  id        String @id @default(uuid())
  invoiceId String
  itemId    String
  qty       Int
  rate      Float
  amount    Float

  invoice PurchaseInvoice @relation(fields: [invoiceId], references: [id])
  item    ItemNew         @relation(fields: [itemId], references: [id])
}

model InventoryTxn {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  type String // PURCHASE | SALE | SALE_RETURN
  date DateTime

  itemId    String
  qty       Int
  rate      Float
  amount    Float
  accountId String?
  location  String  @default("MAIN") // ðŸ‘ˆ GODOWN / LOCATION

  // ðŸ”¥ PARTY LINK
  partyId String?
  party   Account? @relation(fields: [partyId], references: [id])

  item ItemNew @relation(fields: [itemId], references: [id])

  createdAt DateTime @default(now())
}

model SalesInvoice {
  id           String      @id @default(uuid())
  companyId    String
  company      Company     @relation(fields: [companyId], references: [id])
  branchId     String?
  branch       Branch?     @relation(fields: [branchId], references: [id])
  costCenterId String?
  costCenter   CostCenter? @relation(fields: [costCenterId], references: [id])

  invoiceNo String
  date      DateTime
  total     Float

  customerId String
  customer   Account @relation("SalesCustomer", fields: [customerId], references: [id])

  taxConfigId String?
  taxConfig   TaxConfiguration? @relation("SalesTax", fields: [taxConfigId], references: [id])

  items   SalesInvoiceItem[]
  returns SaleReturn[]       @relation("InvoiceReturns")

  driverName String?
  vehicleNo  String?

  approvalStatus  String    @default("DRAFT") // DRAFT | PENDING | APPROVED | REJECTED
  approvedBy      String?
  approvedAt      DateTime?
  approvalRemarks String?

  createdAt DateTime  @default(now())
  deletedAt DateTime?
  deletedBy String?
}

model SalesInvoiceItem {
  id        String @id @default(uuid())
  invoiceId String
  itemId    String
  qty       Int
  rate      Float
  amount    Float

  invoice SalesInvoice @relation(fields: [invoiceId], references: [id])
  item    ItemNew      @relation(fields: [itemId], references: [id])
}

model Voucher {
  id           String      @id @default(uuid())
  companyId    String?
  company      Company?    @relation(fields: [companyId], references: [id])
  branchId     String?
  branch       Branch?     @relation(fields: [branchId], references: [id])
  costCenterId String?
  costCenter   CostCenter? @relation(fields: [costCenterId], references: [id])

  voucherNo String
  type      String
  date      DateTime
  narration String?
  createdAt DateTime @default(now())

  entries         VoucherEntry[] // ðŸ”¥ THIS IS REQUIRED
  paymentReceipts PaymentReceipt[]
  expenseVouchers ExpenseVoucher[]

  deletedAt DateTime?
  deletedBy String?
}

model VoucherEntry {
  id        String   @id @default(uuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  voucherId String
  accountId String
  amount    Float // +ve = Debit, -ve = Credit

  voucher Voucher @relation(fields: [voucherId], references: [id])
  account Account @relation(fields: [accountId], references: [id])
}

model StockRate {
  id        String   @id @default(uuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  itemId String
  rate   Float
  date   DateTime

  item ItemNew @relation(fields: [itemId], references: [id])

  createdAt DateTime @default(now())
}

model SaleReturn {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  returnNo String
  date     DateTime

  invoiceId String? // ðŸ‘ˆ OPTIONAL
  invoice   SalesInvoice? @relation("InvoiceReturns", fields: [invoiceId], references: [id])

  customerId String
  customer   Account @relation("SaleReturnCustomer", fields: [customerId], references: [id])

  total      Float
  driverName String?
  vehicleNo  String?
  remarks    String?
  items      SaleReturnItem[]

  createdAt DateTime @default(now())
}

model SaleReturnItem {
  id       String @id @default(uuid())
  returnId String
  itemId   String
  qty      Int
  rate     Float
  amount   Float

  saleReturn SaleReturn @relation(fields: [returnId], references: [id])
  item       ItemNew    @relation(fields: [itemId], references: [id])
}

model Outward {
  id        String  @id @default(uuid()) // Ø§Ø³Û’ String ÛÛŒ Ø±Ú©Ú¾ÛŒÚº
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  outwardNo  Int           @unique
  date       DateTime
  customerId String
  customer   Account       @relation(fields: [customerId], references: [id])
  driverName String?
  vehicleNo  String?
  remarks    String?
  items      OutwardItem[]
  createdAt  DateTime      @default(now())
}

model OutwardItem {
  id        String @id @default(uuid())
  outwardId String // ØµØ±Ù ÛŒÛ Ø§ÛŒÚ© Ù„Ø§Ø¦Ù† ÛÙˆÙ†ÛŒ Ú†Ø§ÛÛŒÛ’
  itemId    String
  qty       Int
  rate      Float?
  amount    Float?

  outward Outward @relation(fields: [outwardId], references: [id])
  item    ItemNew @relation(fields: [itemId], references: [id])
}

model Company {
  id        String  @id @default(uuid())
  name      String
  code      String?
  isActive  Boolean @default(true)
  country   String?  @default("United States")
  baseCurrency String @default("USD")
  plan      String   @default("STARTER")
  businessType  String  @default("trading") // trading|manufacturing|distribution|retail|service|restaurant|real_estate|construction
  businessSetupDone Boolean @default(false)
  activeModules String? // Comma separated IDs for Custom plan
  customPrice   Float?
  subscriptionStatus String? @default("ACTIVE")
  stripeCustomerId   String?
  currentPeriodEnd    DateTime?
  cancelledAt        DateTime?  // Timestamp when subscription was cancelled
  dataRetentionUntil DateTime?  // 90 days after cancellation — hard delete after this date
  fraudRisk          String?    @default("NONE") // NONE | LOW | MEDIUM | HIGH — updated by fraud monitor
  flaggedAt          DateTime?  // When admin manually flagged this company
  flagNote           String?    // Admin note explaining the flag
  createdAt DateTime @default(now())

  users        UserCompany[]
  defaultUsers User[]        @relation("UserDefaultCompany")

  // Billing & Subscriptions
  subscription Subscription?

  // Audit & Logging
  auditLogs AuditLog[] @relation("CompanyAuditLogs")
  loginLogs LoginLog[] @relation("CompanyLoginLogs")

  // Financial Core
  ledgerEntries LedgerEntry[] @relation("CompanyLedgerEntries")

  accounts              Account[]
  items                 ItemNew[]
  purchaseOrders        PurchaseOrder[]
  purchaseInvoices      PurchaseInvoice[]
  inventoryTxns         InventoryTxn[]
  salesInvoices         SalesInvoice[]
  vouchers              Voucher[]
  voucherEntries        VoucherEntry[]
  stockRates            StockRate[]
  saleReturns           SaleReturn[]
  outwards              Outward[]
  employees             Employee[]
  attendances           Attendance[]
  payrolls              Payroll[]
  advanceSalaries       AdvanceSalary[]
  contacts              Contact[]
  quotations            Quotation[]
  deliveryChallans      DeliveryChallan[]
  advancePayments       AdvancePayment[]
  bankAccounts          BankAccount[]
  bankStatements        BankStatement[]
  paymentReceipts       PaymentReceipt[]
  expenseVouchers       ExpenseVoucher[]
  taxConfigurations     TaxConfiguration[]
  budgets               Budget[]
  recurringTransactions RecurringTransaction[]
  financialYears        FinancialYear[]
  currencies            Currency[]
  activityLogs          ActivityLog[]
  rolePermissions       RolePermission[]
  userPermissions       UserPermission[]
  backupSchedules       BackupSchedule[]
  systemBackups         SystemBackup[]
  branches              Branch[]
  goodsReceiptNotes     GoodsReceiptNote[]
  costCenters           CostCenter[]
  departmentBudgets     DepartmentBudget[]
  creditNotes           CreditNote[]
  debitNotes            DebitNote[]
  loans                 Loan[]
  fixedAssets           FixedAsset[]
  sessions              Session[]
  businessRecords       BusinessRecord[]
  teamInvites           TeamInvite[]
  bulkPaymentBatches    BulkPaymentBatch[]
  paymentFollowUpLogs   PaymentFollowUpLog[]
}

model CreditNote {
  id               String   @id @default(uuid())
  companyId        String
  company          Company  @relation(fields: [companyId], references: [id])
  creditNoteNumber String
  date             DateTime
  accountId        String
  account          Account  @relation("CreditNoteAccount", fields: [accountId], references: [id])
  amount           Float
  reason           String
  description      String?
  reference        String?
  status           String   @default("PENDING") // PENDING, APPROVED, APPLIED, CANCELLED
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model DebitNote {
  id              String   @id @default(uuid())
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id])
  debitNoteNumber String
  date            DateTime
  accountId       String
  account         Account  @relation("DebitNoteAccount", fields: [accountId], references: [id])
  amount          Float
  reason          String
  description     String?
  reference       String?
  status          String   @default("PENDING") // PENDING, APPROVED, APPLIED, CANCELLED
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Loan {
  id                String        @id @default(uuid())
  companyId         String
  company           Company       @relation(fields: [companyId], references: [id])
  loanNumber        String
  loanType          String
  accountId         String
  account           Account       @relation("LoanAccount", fields: [accountId], references: [id])
  principalAmount   Float
  interestRate      Float
  tenure            Int
  emi               Float         @default(0)
  startDate         DateTime
  endDate           DateTime?
  status            String        @default("ACTIVE") // ACTIVE, CLOSED, DEFAULTED
  outstandingAmount Float         @default(0)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  payments          LoanPayment[]
}

model LoanPayment {
  id                 String   @id @default(uuid())
  loanId             String
  loan               Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)
  paymentDate        DateTime
  amount             Float
  principalPaid      Float    @default(0)
  interestPaid       Float    @default(0)
  outstandingBalance Float    @default(0)
  createdAt          DateTime @default(now())
}

model FixedAsset {
  id                 String         @id @default(uuid())
  companyId          String
  company            Company        @relation(fields: [companyId], references: [id])
  assetName          String
  assetCode          String
  category           String
  purchaseDate       DateTime
  purchaseValue      Float
  currentValue       Float          @default(0)
  depreciationMethod String         @default("STRAIGHT_LINE")
  depreciationRate   Float
  usefulLife         Int
  salvageValue       Float          @default(0)
  location           String?
  status             String         @default("ACTIVE") // ACTIVE, DISPOSED, SOLD, SCRAPPED
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  depreciations      Depreciation[]
}

model Depreciation {
  id                      String     @id @default(uuid())
  fixedAssetId            String
  fixedAsset              FixedAsset @relation(fields: [fixedAssetId], references: [id], onDelete: Cascade)
  date                    DateTime
  amount                  Float
  accumulatedDepreciation Float      @default(0)
  bookValue               Float      @default(0)
  createdAt               DateTime   @default(now())
}

model UserCompany {
  id        String   @id @default(uuid())
  userId    String
  companyId String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([companyId])
}

model User {
  id               String           @id @default(uuid())
  name             String
  email            String           @unique
  password         String // bcrypt hash
  role             String           @default("VIEWER") // ADMIN, ACCOUNTANT, VIEWER
  active           Boolean          @default(true)
  logs             ActivityLog[]
  createdAt        DateTime         @default(now())
  permissions      UserPermission[]
  defaultCompanyId String?
  defaultCompany   Company?         @relation("UserDefaultCompany", fields: [defaultCompanyId], references: [id])
  companies        UserCompany[]
  loginLogs        LoginLog[]       @relation("UserLoginLogs")
  sessions         Session[]

  // 2FA / TOTP
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?

  // Referral
  referralCode String? @unique
  referrals    Referral[] @relation("ReferrerUser")
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime
  ip        String?
  userAgent String?
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])

  @@index([userId, companyId])
}

model ActivityLog {
  id        String  @id @default(cuid())
  action    String
  details   String?
  userId    String?
  companyId String?

  createdAt DateTime @default(now())

  user    User?    @relation(fields: [userId], references: [id])
  company Company? @relation(fields: [companyId], references: [id])

  @@index([companyId])
}

model RolePermission {
  id         String @id @default(uuid())
  role       String // ADMIN | ACCOUNTANT | VIEWER
  permission String // e.g. CREATE_USER

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  @@unique([role, permission, companyId])
  @@index([companyId])
}

model UserPermission {
  id         String @id @default(uuid())
  userId     String
  permission String
  companyId  String

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, permission, companyId])
  @@index([companyId])
}

// ================= PHASE 1: BANKING & PAYMENT MODELS =================

model BankAccount {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  accountNo       String               @unique
  bankName        String
  accountName     String
  balance         Float                @default(0)
  lastReconcile   DateTime?
  accountId       String
  account         Account              @relation(fields: [accountId], references: [id])
  statements      BankStatement[]
  reconciliations BankReconciliation[]

  // Plaid Integration Fields
  plaidAccessToken String?
  plaidItemId      String?
  institutionId    String?
  isPlaidLinked    Boolean  @default(false)

  createdAt     DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  deletedAt     DateTime?
  deletedBy     String?
}

model BankStatement {
  id               String              @id @default(uuid())
  companyId        String?
  company          Company?            @relation(fields: [companyId], references: [id])
  bankAccountId    String
  bankAccount      BankAccount         @relation(fields: [bankAccountId], references: [id])
  statementNo      String
  date             DateTime
  amount           Float
  description      String
  referenceNo      String?
  isReconciled     Boolean             @default(false)
  reconciliationId String?
  reconciliation   BankReconciliation? @relation(fields: [reconciliationId], references: [id])
  createdAt        DateTime            @default(now())
}

model BankReconciliation {
  id            String          @id @default(uuid())
  bankAccountId String
  bankAccount   BankAccount     @relation(fields: [bankAccountId], references: [id])
  reconcileDate DateTime
  systemBalance Float
  bankBalance   Float
  difference    Float
  narration     String?
  statements    BankStatement[]
  createdAt     DateTime        @default(now())
}

model PaymentReceipt {
  id           String      @id @default(uuid())
  companyId    String
  company      Company     @relation(fields: [companyId], references: [id])
  branchId     String?
  branch       Branch?     @relation(fields: [branchId], references: [id])
  costCenterId String?
  costCenter   CostCenter? @relation(fields: [costCenterId], references: [id])

  receiptNo       String    @unique
  date            DateTime
  amount          Float
  paymentMode     String // CASH | CHECK | BANK_TRANSFER
  partyId         String?
  party           Account?  @relation(fields: [partyId], references: [id])
  referenceNo     String?
  narration       String?
  status          String    @default("PENDING") // PENDING | POSTED | RECONCILED
  approvalStatus  String    @default("PENDING") // PENDING | APPROVED | REJECTED
  approvedBy      String?
  approvedAt      DateTime?
  approvalRemarks String?
  voucherId       String?
  voucher         Voucher?  @relation(fields: [voucherId], references: [id])
  createdAt       DateTime  @default(now())
  deletedAt       DateTime?
  deletedBy       String?
}

model ExpenseVoucher {
  id           String      @id @default(uuid())
  companyId    String
  company      Company     @relation(fields: [companyId], references: [id])
  branchId     String?
  branch       Branch?     @relation(fields: [branchId], references: [id])
  costCenterId String?
  costCenter   CostCenter? @relation(fields: [costCenterId], references: [id])

  voucherNo        String              @unique
  date             DateTime
  description      String
  totalAmount      Float
  approvalStatus   String              @default("DRAFT") // DRAFT | PENDING | APPROVED | REJECTED
  expenseAccountId String
  expenseAccount   Account             @relation("ExpenseAccount", fields: [expenseAccountId], references: [id])
  paymentAccountId String
  paymentAccount   Account             @relation("PaymentAccount", fields: [paymentAccountId], references: [id])
  voucherId        String?
  voucher          Voucher?            @relation(fields: [voucherId], references: [id])
  items            ExpenseItem[]
  attachments      ExpenseAttachment[]
  approvals        ExpenseApproval[]
  createdAt        DateTime            @default(now())
  deletedAt        DateTime?
  deletedBy        String?
}

model ExpenseItem {
  id               String         @id @default(uuid())
  expenseVoucherId String
  expenseVoucher   ExpenseVoucher @relation(fields: [expenseVoucherId], references: [id], onDelete: Cascade)
  description      String
  amount           Float
  category         String // TRAVEL | FOOD | SUPPLIES | UTILITIES | OTHER
}

model ExpenseAttachment {
  id               String         @id @default(uuid())
  expenseVoucherId String
  expenseVoucher   ExpenseVoucher @relation(fields: [expenseVoucherId], references: [id], onDelete: Cascade)
  fileName         String
  fileUrl          String
  fileSize         Int
  uploadedAt       DateTime       @default(now())
}

model ExpenseApproval {
  id               String         @id @default(uuid())
  expenseVoucherId String
  expenseVoucher   ExpenseVoucher @relation(fields: [expenseVoucherId], references: [id], onDelete: Cascade)
  approverId       String
  approvalStatus   String // APPROVED | REJECTED
  remarks          String?
  approvedAt       DateTime       @default(now())
}

model TaxConfiguration {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  taxType          String // GST | VAT | INCOME_TAX | SALES_TAX
  taxCode          String            @unique
  taxRate          Float
  description      String?
  isActive         Boolean           @default(true)
  taxAccounts      TaxAccount[]
  invoiceTaxes     InvoiceTax[]
  salesInvoices    SalesInvoice[]    @relation("SalesTax")
  purchaseInvoices PurchaseInvoice[] @relation("PurchaseTax")
  createdAt        DateTime          @default(now())
}

model TaxAccount {
  id                 String           @id @default(uuid())
  taxConfigurationId String
  taxConfiguration   TaxConfiguration @relation(fields: [taxConfigurationId], references: [id], onDelete: Cascade)
  accountId          String
  account            Account          @relation(fields: [accountId], references: [id])
  taxType            String

  @@unique([taxConfigurationId, accountId, taxType])
}

model InvoiceTax {
  id                 String           @id @default(uuid())
  invoiceType        String // SALES | PURCHASE
  invoiceId          String
  taxConfigurationId String
  taxConfiguration   TaxConfiguration @relation(fields: [taxConfigurationId], references: [id])
  subtotal           Float
  taxAmount          Float
  totalAmount        Float
  createdAt          DateTime         @default(now())
}

// ================= ADVANCED FEATURES =================

model Budget {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  accountId   String
  account     Account  @relation(fields: [accountId], references: [id])
  year        Int
  month       Int? // null = annual budget
  amount      Float
  category    String? // Optional category
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([accountId, year, month])
  @@index([year, month])
}

model RecurringTransaction {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  accountId   String
  account     Account   @relation(fields: [accountId], references: [id])
  type        String // CPV | CRV | JV | EXPENSE | PAYMENT
  frequency   String // DAILY | WEEKLY | MONTHLY | QUARTERLY | YEARLY
  amount      Float
  description String
  narration   String?
  nextDate    DateTime
  lastRun     DateTime?
  isActive    Boolean   @default(true)
  metadata    String? // JSON string for additional data
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([nextDate, isActive])
}

model FinancialYear {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  year      Int       @unique
  startDate DateTime
  endDate   DateTime
  isActive  Boolean   @default(false)
  isClosed  Boolean   @default(false)
  closedAt  DateTime?
  closedBy  String?
  createdAt DateTime  @default(now())

  @@index([year, isActive])
}

model SystemBackup {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  fileName   String
  filePath   String?
  fileSize   Int?
  backupType String // FULL | PARTIAL
  status     String // PENDING | COMPLETED | FAILED
  metadata   String? // JSON string
  createdAt  DateTime @default(now())
  createdBy  String?

  @@index([companyId, createdAt, status])
}

model BackupSchedule {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  frequency  String // DAILY | WEEKLY | MONTHLY
  timeOfDay  String // HH:mm
  dayOfWeek  Int? // 0-6 (Sun-Sat)
  dayOfMonth Int? // 1-31
  isActive   Boolean   @default(true)
  lastRunAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId])
}

model Branch {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  code      String
  name      String
  city      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  purchaseOrders    PurchaseOrder[]
  purchaseInvoices  PurchaseInvoice[]
  salesInvoices     SalesInvoice[]
  vouchers          Voucher[]
  paymentReceipts   PaymentReceipt[]
  expenseVouchers   ExpenseVoucher[]
  quotations        Quotation[]
  deliveryChallans  DeliveryChallan[]
  goodsReceiptNotes GoodsReceiptNote[]
  contacts          Contact[]

  @@unique([companyId, code])
  @@index([companyId, isActive])
}

model CostCenter {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  code      String
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  purchaseOrders   PurchaseOrder[]
  purchaseInvoices PurchaseInvoice[]
  salesInvoices    SalesInvoice[]
  vouchers         Voucher[]
  paymentReceipts  PaymentReceipt[]
  expenseVouchers  ExpenseVoucher[]
  quotations       Quotation[]
  deliveryChallans DeliveryChallan[]

  @@unique([companyId, code])
  @@index([companyId, isActive])
}

model DepartmentBudget {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  department  String
  year        Int
  month       Int?
  amount      Float
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([companyId, department, year, month])
  @@index([companyId, year, month])
}

// ================= FEATURE 4: MULTI-CURRENCY SUPPORT =================

model Currency {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  code         String   @unique // USD, EUR, GBP, PKR, etc.
  name         String
  symbol       String
  isActive     Boolean  @default(true)
  exchangeRate Float    @default(1.0) // Rate against company base currency (e.g. USD)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  transactions CurrencyTransaction[]

  @@index([code, isActive])
}

model CustomPlanRequest {
  id        String   @id @default(uuid())
  email     String
  name      String
  company   String
  modules   String // Comma separated IDs
  price     Float
  status    String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ModulePrice {
  id        String   @id @default(uuid())
  moduleId  String   @unique
  price     Float
  updatedAt DateTime @updatedAt
}

model CurrencyTransaction {
  id              String   @id @default(uuid())
  transactionType String // INVOICE | PAYMENT | EXPENSE | CONVERSION
  transactionId   String // Reference to original transaction
  currencyId      String
  currency        Currency @relation(fields: [currencyId], references: [id])
  amountInLocal   Float
  amountInBase    Float // Converted to company base currency
  exchangeRate    Float // Rate used at time of transaction
  conversionDate  DateTime
  createdAt       DateTime @default(now())

  @@index([transactionType, transactionId, currencyId])
}

// ================= FEATURE 6: ATTENDANCE/HR MODULE =================

model Employee {
  id        String   @id @default(uuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  employeeId      String
  firstName       String
  lastName        String
  email           String
  phone           String?
  designations    String // Job title
  department      String
  dateOfJoining   DateTime
  dateOfBirth     DateTime?
  cnic            String?
  address         String?
  city            String?
  salary          Float
  salaryFrequency String // MONTHLY | WEEKLY | HOURLY
  accountId       String? // Link to Chart of Accounts if needed
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  attendances Attendance[]
  leaves      Leave[]
  payroll     Payroll[]
  advances    AdvanceSalary[]
  documents   EmployeeDocument[]

  @@index([department, isActive])
  @@index([email])
  @@unique([companyId, employeeId])
  @@unique([companyId, email])
}

model Attendance {
  id        String   @id @default(uuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  employeeId String
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date       DateTime
  status     String // PRESENT | ABSENT | LEAVE | HALF_DAY | LATE
  checkIn    DateTime?
  checkOut   DateTime?
  remarks    String?
  createdAt  DateTime  @default(now())

  @@unique([employeeId, date])
  @@index([employeeId, date])
}

model Leave {
  id             String   @id @default(uuid())
  employeeId     String
  employee       Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType      String // CASUAL | SICK | ANNUAL | UNPAID
  startDate      DateTime
  endDate        DateTime
  totalDays      Int
  approvalStatus String   @default("PENDING") // PENDING | APPROVED | REJECTED
  approvedBy     String?
  reason         String
  attachmentUrl  String?
  createdAt      DateTime @default(now())

  @@index([employeeId, startDate])
}

model Payroll {
  id        String   @id @default(uuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  employeeId      String
  employee        Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  monthYear       String // YYYY-MM
  baseSalary      Float
  allowances      Float     @default(0) // HRA, DA, etc.
  deductions      Float     @default(0) // Tax, insurance, etc.
  additionalCash  Float     @default(0)
  netSalary       Float
  paidAmount      Float     @default(0)
  paymentStatus   String    @default("PENDING") // PENDING | PAID | PARTIAL
  paymentDate     DateTime?
  remarks         String?
  createdAt       DateTime  @default(now())
  deductionReason String?

  @@unique([employeeId, monthYear])
  @@index([employeeId, monthYear, paymentStatus])
}

model AdvanceSalary {
  id        String   @id @default(uuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  amount     Float
  date       DateTime
  monthYear  String? // Target deduction month (YYYY-MM). If null, pending until deducted.
  status     String   @default("PENDING") // PENDING | DEDUCTED
  remarks    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  deletedAt DateTime?
  deletedBy String?

  @@index([employeeId, status])
  @@index([monthYear])
}

model EmployeeDocument {
  id         String    @id @default(uuid())
  employeeId String
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  docType    String // CNIC | PASSPORT | DEGREE | CERTIFICATE | CONTRACT
  fileName   String
  fileUrl    String
  uploadDate DateTime  @default(now())
  expiryDate DateTime?
  createdAt  DateTime  @default(now())

  @@index([employeeId, docType])
}

// ================= FEATURE 7: CRM FEATURES =================

model Contact {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])
  branchId  String?
  branch    Branch? @relation(fields: [branchId], references: [id])

  name        String
  email       String?
  phone       String
  companyName String
  position    String? // Job title
  type        String // CUSTOMER | SUPPLIER | LEAD | PARTNER
  accountId   String? // Link to Chart of Accounts
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  deletedAt DateTime?
  deletedBy String?

  interactions  Interaction[]
  opportunities Opportunity[]
  documents     ContactDocument[]
  notes         ContactNote[]

  @@index([type, isActive])
  @@index([email, phone])
  @@index([branchId])
  @@unique([companyId, email])
}

model Interaction {
  id           String    @id @default(uuid())
  contactId    String
  contact      Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  type         String // CALL | EMAIL | MEETING | MESSAGE | VISIT
  date         DateTime
  subject      String
  description  String
  outcome      String? // POSITIVE | NEGATIVE | NEUTRAL
  nextFollowUp DateTime?
  createdBy    String? // User ID
  createdAt    DateTime  @default(now())

  @@index([contactId, date])
  @@index([type, date])
}

model Opportunity {
  id                String    @id @default(uuid())
  contactId         String
  contact           Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  title             String
  description       String
  value             Float
  probability       Int       @default(50) // 0-100
  stage             String // LEAD | PROSPECT | NEGOTIATION | CLOSE | WON | LOST
  expectedCloseDate DateTime
  actualCloseDate   DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  activities OpportunityActivity[]

  @@index([contactId, stage])
  @@index([stage, expectedCloseDate])
}

model OpportunityActivity {
  id            String      @id @default(uuid())
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  activityType  String // CALL | EMAIL | MEETING | PROPOSAL | FOLLOW_UP
  date          DateTime
  description   String
  status        String // COMPLETED | PENDING | CANCELLED
  createdAt     DateTime    @default(now())

  @@index([opportunityId, date])
}

model ContactDocument {
  id         String   @id @default(uuid())
  contactId  String
  contact    Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  docType    String // QUOTE | PROPOSAL | CONTRACT | INVOICE | AGREEMENT
  fileName   String
  fileUrl    String
  uploadDate DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([contactId, docType])
}

model ContactNote {
  id        String   @id @default(uuid())
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  content   String
  isPrivate Boolean  @default(false)
  createdBy String? // User ID
  createdAt DateTime @default(now())

  @@index([contactId, createdAt])
}

// ================= FEATURE 8: QUOTATION & DELIVERY CHALLAN =================

model Quotation {
  id           String      @id @default(uuid())
  companyId    String
  company      Company     @relation(fields: [companyId], references: [id])
  branchId     String?
  branch       Branch?     @relation(fields: [branchId], references: [id])
  costCenterId String?
  costCenter   CostCenter? @relation(fields: [costCenterId], references: [id])

  quotationNo     String
  date            DateTime
  total           Float
  freight         Float     @default(0)
  remarks         String?
  validUntil      DateTime?
  status          String    @default("DRAFT") // DRAFT | SENT | ACCEPTED | REJECTED
  approvalStatus  String    @default("DRAFT")
  approvedBy      String?
  approvedAt      DateTime?
  approvalRemarks String?

  @@unique([quotationNo, companyId])

  customerId   String?
  customer     Account? @relation("QuotationCustomer", fields: [customerId], references: [id])
  customerName String? // For ad-hoc customers

  items     QuotationItem[]
  createdAt DateTime        @default(now())
}

model QuotationItem {
  id          String @id @default(uuid())
  quotationId String
  itemId      String
  qty         Int
  rate        Float
  amount      Float

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  item      ItemNew   @relation(fields: [itemId], references: [id])
}

model DeliveryChallan {
  id           String      @id @default(uuid())
  companyId    String
  company      Company     @relation(fields: [companyId], references: [id])
  branchId     String?
  branch       Branch?     @relation(fields: [branchId], references: [id])
  costCenterId String?
  costCenter   CostCenter? @relation(fields: [costCenterId], references: [id])

  challanNo String   @unique
  date      DateTime

  customerId String
  customer   Account @relation("ChallanCustomer", fields: [customerId], references: [id])

  driverName String?
  vehicleNo  String?
  remarks    String?

  items           DeliveryChallanItem[]
  status          String                @default("PENDING") // PENDING | DELIVERED | INVOICED
  approvalStatus  String                @default("DRAFT")
  approvedBy      String?
  approvedAt      DateTime?
  approvalRemarks String?

  createdAt DateTime @default(now())
}

model DeliveryChallanItem {
  id        String @id @default(uuid())
  challanId String
  itemId    String
  qty       Int
  rate      Float? // Optional in Challan

  challan DeliveryChallan @relation(fields: [challanId], references: [id], onDelete: Cascade)
  item    ItemNew         @relation(fields: [itemId], references: [id])
}

// ================= FEATURE 9: ADVANCE PAYMENT TO SUPPLIERS =================

model AdvancePayment {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  advanceNo      String   @unique
  date           DateTime
  amount         Float
  adjustedAmount Float    @default(0)
  balance        Float
  status         String   @default("OPEN") // OPEN | ADJUSTED | CLOSED

  supplierId String
  supplier   Account @relation("SupplierAdvances", fields: [supplierId], references: [id])

  narration String?

  adjustments AdvanceAdjustment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdvanceAdjustment {
  id               String         @id @default(uuid())
  advancePaymentId String
  advancePayment   AdvancePayment @relation(fields: [advancePaymentId], references: [id], onDelete: Cascade)

  invoiceNo String
  amount    Float
  date      DateTime
  remarks   String?

  createdAt DateTime @default(now())
}

// ================= BILLING & SUBSCRIPTIONS =================

model Subscription {
  id        String  @id @default(uuid())
  companyId String  @unique
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  plan                 String // STARTER | PROFESSIONAL | ENTERPRISE
  status               String  @default("ACTIVE") // ACTIVE | SUSPENDED | CANCELLED | EXPIRED
  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique

  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean   @default(false)
  canceledAt         DateTime?

  billingCycle       String    @default("MONTHLY") // MONTHLY | YEARLY
  pricePerMonth      Float     @default(0)
  totalPaid          Float     @default(0)
  failedPayments     Int       @default(0)
  lastPaymentAttempt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, currentPeriodEnd])
}

// ================= LOGIN & GEO TRACKING =================

model LoginLog {
  id        String  @id @default(uuid())
  userId    String
  user      User    @relation("UserLoginLogs", fields: [userId], references: [id], onDelete: Cascade)
  companyId String
  company   Company @relation("CompanyLoginLogs", fields: [companyId], references: [id], onDelete: Cascade)

  ipAddress   String?
  country     String? // Resolved from GeoIP
  countryCode String? // ISO code (e.g., PK, US)
  city        String?
  userAgent   String?

  loginAt         DateTime  @default(now())
  logoutAt        DateTime?
  sessionDuration Int? // seconds

  @@index([userId, loginAt])
  @@index([companyId, loginAt])
  @@index([country, loginAt])
}

// ================= AUDIT LOGGING =================

model AuditLog {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation("CompanyAuditLogs", fields: [companyId], references: [id], onDelete: Cascade)

  entity   String // e.g. "SalesInvoice", "Account", "Subscription"
  entityId String // UUID of the entity
  action   String // CREATE | READ | UPDATE | DELETE

  userId   String?
  userName String? // Cached for deleted users
  userRole String?

  beforeValues String? // JSON snapshot of before state
  afterValues  String? // JSON snapshot of after state

  description String?

  createdAt DateTime @default(now())

  @@index([companyId, createdAt])
  @@index([entity, entityId])
  @@index([userId, createdAt])
  @@index([action])
}

// ================= LEDGER ENTRIES (Financial Core) =================

model LedgerEntry {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation("CompanyLedgerEntries", fields: [companyId], references: [id], onDelete: Cascade)

  accountId String
  account   Account @relation("AccountLedgerEntries", fields: [accountId], references: [id], onDelete: Cascade)

  voucherId String? // Link to voucher
  invoiceId String? // Link to sales/purchase invoice

  debit  Float @default(0)
  credit Float @default(0)

  description String?
  date        DateTime

  createdAt DateTime @default(now())

  @@index([companyId, accountId, date])
  @@index([date])
  @@index([accountId])
}

model Notification {
  id        String   @id @default(uuid())
  title     String
  message   String
  type      String   @default("INFO") // INFO | WARNING | ERROR | SUCCESS
  link      String? // Optional link to redirect
  isRead    Boolean  @default(false)
  userId    String? // If null, it's for all admins
  createdAt DateTime @default(now())

  @@index([isRead, createdAt])
}

// Update User model to add LoginLog relation
// (Note: This is handled by adding the @relation in the User model)

// =================== GRN (GOODS RECEIPT NOTE) ===================

model GoodsReceiptNote {
  id           String      @id @default(uuid())
  companyId    String
  company      Company     @relation(fields: [companyId], references: [id])
  branchId     String?
  branch       Branch?     @relation(fields: [branchId], references: [id])

  grnNo        String
  date         DateTime
  poId         String?
  po           PurchaseOrder? @relation(fields: [poId], references: [id])
  supplierId   String
  supplier     Account     @relation("GRNSupplier", fields: [supplierId], references: [id])

  remarks      String?
  status       String      @default("DRAFT") // DRAFT | RECEIVED | PARTIAL | CANCELLED

  items        GoodsReceiptNoteItem[]

  createdAt    DateTime    @default(now())
  createdBy    String?
  deletedAt    DateTime?
  deletedBy    String?

  @@index([companyId])
  @@index([date])
}

model GoodsReceiptNoteItem {
  id        String           @id @default(uuid())
  grnId     String
  grn       GoodsReceiptNote @relation(fields: [grnId], references: [id], onDelete: Cascade)
  itemId    String
  item      ItemNew          @relation(fields: [itemId], references: [id])

  orderedQty  Int
  receivedQty Int
  rate        Float
  amount      Float
  remarks     String?
}

// ─── Live Chat ───────────────────────────────────────────────────────────────

model ChatConversation {
  id            String        @id @default(uuid())
  customerName  String
  customerEmail String?
  status        String        @default("bot") // bot | waiting | agent | closed
  assignedAgent String?
  companyId     String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  messages      ChatMessage[]
}

model ChatMessage {
  id             String           @id @default(uuid())
  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         String           // customer | bot | agent
  text           String           @db.Text
  createdAt      DateTime         @default(now())
}

// ─── Admin Team Members ───────────────────────────────────────────────────────

model AdminUser {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  passwordHash String
  isSuperAdmin Boolean   @default(false)
  allowedPages String    @default("[]") // JSON array of page names
  team         String?   // e.g. "Contact Team", "Marketing Team"
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  lastLoginAt  DateTime?
}

// ─── Coupons ──────────────────────────────────────────────────────────────────

model Coupon {
  id           String             @id @default(uuid())
  code         String             @unique
  type         String             // percent | fixed
  value        Float
  maxUses      Int?
  usedCount    Int                @default(0)
  expiresAt    DateTime?
  applicableTo String?            // null = all | starter | pro | enterprise

  // Targeting — all null = open to everyone
  allowedEmails        String?   // JSON array of user emails e.g. ["ali@co.com","sara@x.com"]
  allowedCompanyIds    String?   // JSON array of company IDs
  allowedBusinessTypes String?   // JSON array of business type slugs e.g. ["trading","distribution"]
  allowedCountries     String?   // JSON array of ISO country codes e.g. ["PK","AE","SA"]

  active       Boolean            @default(true)
  createdAt    DateTime           @default(now())
  redemptions  CouponRedemption[]
}

model CouponRedemption {
  id        String   @id @default(uuid())
  couponId  String
  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  userId    String?
  companyId String?
  createdAt DateTime @default(now())
}

// ─── Email Logs ───────────────────────────────────────────────────────────────

model EmailLog {
  id        String   @id @default(uuid())
  to        String
  subject   String
  status    String   // sent | failed
  error     String?
  createdAt DateTime @default(now())
}

// ─── Referrals ────────────────────────────────────────────────────────────────

model Referral {
  id           String    @id @default(uuid())
  referrerId   String
  referrer     User      @relation("ReferrerUser", fields: [referrerId], references: [id])
  refereeEmail String
  status       String    @default("pending") // pending | signed_up | converted
  reward       Float?
  createdAt    DateTime  @default(now())
  convertedAt  DateTime?
}

// ─── Testimonials ─────────────────────────────────────────────────────────────

model Testimonial {
  id        String   @id @default(uuid())
  name      String
  company   String?
  role      String?
  message   String
  rating    Int      @default(5)
  avatar    String?
  planUsed  String?
  status    String   @default("PENDING")   // PENDING | PUBLISHED | REJECTED
  featured  Boolean  @default(false)
  userId    String?
  companyId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Website Visitor Tracking ────────────────────────────────────────────────

model SiteVisit {
  id          String   @id @default(cuid())
  sessionId   String   // anonymous browser session ID
  page        String
  referrer    String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  country     String?
  countryName String?
  city        String?
  flag        String?
  device      String?  // mobile | desktop | tablet
  browser     String?
  os          String?
  ip          String?
  lat         Float?
  lon         Float?
  duration    Int?     // seconds on page
  visitedAt   DateTime @default(now())

  @@index([sessionId])
  @@index([visitedAt])
  @@index([country])
  @@index([page])
}

// ─── Leads ────────────────────────────────────────────────────────────────────

model Lead {
  id          String    @id @default(uuid())
  name        String
  email       String
  phone       String?
  company     String?
  message     String?
  source      String?   // contact-form | demo-request | manual | visitor | newsletter
  status      String    @default("new") // new | contacted | demo | proposal | converted | lost
  priority    String    @default("medium") // low | medium | high
  notes       String?   @db.Text
  followUpAt  DateTime?
  assignedTo  String?   // user name or email
  country     String?
  sessionId   String?   // link to SiteVisit sessions
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([email])
}


// ─── Business Records (generic store for all business types) ──────────────────
// Handles: hospital patients/appointments, salon bookings, gym memberships,
// real-estate tenants/leases, law cases, IT projects/sprints, etc.

model BusinessRecord {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branchId    String?

  category    String   // e.g. "patient", "appointment", "member", "case", "tenant"
  subCategory String?  // e.g. "lab", "hair", "criminal" — optional sub-grouping
  title       String   // searchable display name
  status      String   @default("active")
  refId       String?  // link to another BusinessRecord (e.g. appointment → patient)
  data        Json     // all business-specific fields as JSON
  amount      Float?   // for financial records (rent, billing, membership fee, etc.)
  date        DateTime? // for date-based records (appointment date, hearing date, etc.)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId, category])
  @@index([companyId, category, status])
  @@index([refId])
}

// ── Support & Tickets ────────────────────────────────────────────────────────

model SupportTicket {
  id        String   @id @default(uuid())
  companyId String?
  userId    String?
  subject   String
  message   String   @db.Text
  status    String   @default("OPEN") // OPEN | IN_PROGRESS | CLOSED
  priority  String   @default("MEDIUM") // LOW | MEDIUM | HIGH | URGENT
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Team Invitations ─────────────────────────────────────────────────────────

model TeamInvite {
  id        String   @id @default(uuid())
  email     String
  role      String   @default("USER")
  token     String   @unique
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  status    String   @default("PENDING") // PENDING | ACCEPTED | EXPIRED
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([email])
}

// ── Business Waitlist ─────────────────────────────────────────────────────────
// "Notify me when live" requests for coming-soon business types

model BusinessWaitlist {
  id           String    @id @default(cuid())
  email        String
  businessType String                       // e.g. "manufacturing", "hospital"
  name         String?
  createdAt    DateTime  @default(now())
  notified     Boolean   @default(false)
  notifiedAt   DateTime?

  @@unique([email, businessType])
  @@index([businessType])
  @@index([notified])
}

// ── Admin Action Log ──────────────────────────────────────────────────────────
// ── Newsletter Subscribers ────────────────────────────────────────────────────
// Stores emails of website visitors / users who subscribed for news & offers

model NewsletterSubscriber {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String?
  source          String?                       // "landing" | "footer" | "pricing" | "blog" | "app"
  status          String    @default("active")  // active | unsubscribed
  createdAt       DateTime  @default(now())
  unsubscribedAt  DateTime?

  @@index([status])
  @@index([createdAt])
}

// ── Feedback (Complaints & Suggestions) ──────────────────────────────────────
// Separate from Testimonial — covers complaints, bug reports, suggestions

model Feedback {
  id          String    @id @default(cuid())
  type        String                          // complaint | suggestion | bug | general
  subject     String
  message     String    @db.Text
  email       String?                         // for public (non-logged-in) submissions
  name        String?
  status      String    @default("open")      // open | in_review | resolved | closed
  priority    String    @default("normal")    // low | normal | high | urgent
  userId      String?
  companyId   String?
  adminNote   String?   @db.Text
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, createdAt])
  @@index([type])
  @@index([userId])
  @@index([companyId])
}

// Tracks all actions performed by admin panel users (super admin + team members)

model AdminActionLog {
  id          String   @id @default(uuid())
  adminId     String                       // AdminUser.id or super-admin User.id
  adminEmail  String
  action      String                       // CHANGE_PLAN | IMPERSONATE | DELETE_USER | UPDATE_COMPANY | etc.
  targetType  String                       // Company | User | Subscription | etc.
  targetId    String?
  targetLabel String?                      // Company name or user email for quick display
  companyId   String?                      // Affected company (if applicable)
  details     String?  @db.Text           // JSON snapshot of before/after or extra context
  createdAt   DateTime @default(now())

  @@index([adminId, createdAt])
  @@index([companyId, createdAt])
  @@index([action])
}

// ================= BULK PAYMENTS =================

model BulkPaymentBatch {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])
  branchId  String?

  name      String
  status    String   @default("DRAFT") // DRAFT | SUBMITTED | PROCESSED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rows BulkPaymentRow[]

  @@index([companyId, status])
}

model BulkPaymentRow {
  id      String           @id @default(uuid())
  batchId String
  batch   BulkPaymentBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  partyName  String
  partyType  String   @default("other") // supplier | employee | other
  amount     Float
  reference  String?
  method     String   @default("bank") // bank | cash | cheque
  status     String   @default("PENDING") // PENDING | APPROVED | PROCESSED | FAILED
  note       String?
  createdAt  DateTime @default(now())

  @@index([batchId, status])
}

// ================= PAYMENT FOLLOW-UP =================

model PaymentFollowUpLog {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  invoiceId  String  // SalesInvoice.id
  status     String  @default("PENDING") // PENDING | CONTACTED | PROMISED | PAID
  note       String? @db.Text
  updatedBy  String? // User.id
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  @@unique([companyId, invoiceId])
  @@index([companyId, status])
}
